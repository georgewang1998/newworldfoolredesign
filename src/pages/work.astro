---
import Layout from "../layouts/Layout.astro";
import { films } from "../data/films";
---

<Layout title="Our Work — New World Fool Productions" noSnap>
  <div class="work-page">
    <header class="page-hero">
      <h1>Our Work</h1>
    </header>

    <section class="films-grid">
      {films.map((film) => (
        <a href={`/films/${film.slug}`} class="film-card">
          <div class="card-image">
            <img
              src={film.poster ?? film.stillImage}
              alt={film.title}
              loading="eager"
            />
            <div class="card-overlay" />
            <span class={`status-badge status-${film.status}`}>{film.statusLabel}</span>
          </div>
          <div class="card-info">
            <div class="card-meta">
              <span class="card-year">{film.year}</span>
              <span class="dot" aria-hidden="true">·</span>
              <span class="card-category">{film.category}</span>
            </div>
            <h2 class="card-title">{film.title}</h2>
            <p class="card-tagline">{film.tagline}</p>
          </div>
        </a>
      ))}
    </section>
  </div>
</Layout>

<style>
  .work-page {
    min-height: 100vh;
    padding-bottom: 6rem;
  }

  .page-hero {
    padding: 5rem 2.5rem 4rem;
    border-bottom: 1px solid #1a1a18;
    max-width: 1200px;
    margin: 0 auto;
  }

  h1 {
    font-family: "Bebas Neue", sans-serif;
    font-size: clamp(4rem, 10vw, 8rem);
    font-weight: 400;
    line-height: 0.9;
    color: #F0ECE0;
    letter-spacing: 0.02em;
  }

  .films-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 2.5rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 2.5rem;
  }

  .film-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    group: true;
  }

  .film-card:hover .card-image img {
    transform: scale(1.04);
  }

  .film-card:hover .card-title {
    color: #C8A96E;
  }

  .card-image {
    position: relative;
    aspect-ratio: 2/3;
    overflow: hidden;
    background: #0A0A08;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 50%);
    pointer-events: none;
  }

  .status-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    font-family: "DM Mono", monospace;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.4rem 0.85rem;
    border-radius: 2px;
    backdrop-filter: blur(4px);
  }

  .status-festival {
    background: rgba(200, 169, 110, 0.85);
    color: #000;
    border: 1px solid #C8A96E;
  }

  .status-post-production {
    background: rgba(15, 15, 15, 0.85);
    color: #F0ECE0;
    border: 1px solid rgba(240, 236, 224, 0.5);
  }

  .status-pre-production {
    background: rgba(15, 15, 15, 0.85);
    color: rgba(240, 236, 224, 0.75);
    border: 1px solid rgba(240, 236, 224, 0.35);
  }

  .card-info {
    padding: 1.25rem 0;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .card-year,
  .card-category,
  .dot {
    font-family: "DM Mono", monospace;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    color: rgba(240, 236, 224, 0.4);
    text-transform: uppercase;
  }

  .card-title {
    font-family: "Bebas Neue", sans-serif;
    font-size: 2rem;
    font-weight: 400;
    letter-spacing: 0.03em;
    color: #F0ECE0;
    margin-bottom: 0.6rem;
    transition: color 0.2s;
  }

  .card-tagline {
    font-family: "Cormorant Garamond", serif;
    font-size: 0.9rem;
    font-style: italic;
    font-weight: 300;
    line-height: 1.6;
    color: rgba(240, 236, 224, 0.55);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 640px) {
    .page-hero {
      padding: 3rem 1.5rem 2.5rem;
    }

    .films-grid {
      grid-template-columns: 1fr;
      padding: 2rem 1.5rem;
      gap: 2rem;
    }

    .card-image {
      aspect-ratio: 2/3;
    }
  }
</style>
