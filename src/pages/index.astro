---
import Layout from "../layouts/Layout.astro";
import ProjectAccordion from "../components/ProjectAccordion.astro";
---

<Layout title="New World Fool Productions">
  <!-- 1. Video panel -->
  <div class="jester-panel snap-section">
    <div class="jester-video-bg">
      <iframe
        id="vimeo-bg"
        src="https://player.vimeo.com/video/1180317367?h=cf4f9b47aa&background=1&autoplay=1&loop=1&muted=1&byline=0&title=0"
        style="border:0"
        allow="autoplay; fullscreen"
        title=""
      ></iframe>
      <div class="jester-video-overlay"></div>
    </div>

    <!-- Loading overlay -->
    <div class="video-loader" id="video-loader" aria-hidden="true">
      <img src="/logo.png" alt="" class="loader-logo" />
    </div>

    <section class="video-cta">
      <a href="/work" class="work-link">
        <span class="work-label">Our Work &rsaquo;</span>
      </a>
    </section>

    <div class="scroll-hint" aria-hidden="true">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <path d="M8 3v10M3 9l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
  </div>

  <!-- 2. Film accordion -->
  <ProjectAccordion />

  <!-- 3. Ethos + BTS (bottom — no arrow) -->
  <div class="ethos-bts-panel snap-section">
    <section class="ethos">
      <div class="ethos-left">
        <span>our ethos</span>
      </div>
      <div class="ethos-right">
        <p>The court jester was the only figure in medieval society permitted to speak truth to power. <span class="gold">We carry that ancient tradition into the modern day through cinema.</span></p>
        <a href="/about" class="ethos-link">Learn our story &rsaquo;</a>
      </div>
    </section>

    <section class="bts">
      <div class="bts-rows">
        {(() => {
          // Manually interleaved to avoid clustering similar shots together
          const photos = [
            "/BTS/IMG_9780.jpeg",
            "/BTS/IMG_5447 1.png",
            "/BTS/IMG_9967.jpeg",
            "/BTS/shortfilm-05184 1.png",
            "/BTS/DSC00222.jpg",
            "/BTS/IMG_5442 1.png",
            "/BTS/IMG_9806.jpeg",
            "/BTS/DSC00119.jpg",
            "/BTS/IMG_5430 1.png",
            "/BTS/IMG_9972.jpeg",
            "/BTS/IMG_3725 1.png",
            "/BTS/DSC00139.jpg",
            "/BTS/IMG_5452 1(1).png",
            "/BTS/IMG_0021.jpeg",
            "/BTS/IMG_9824.jpeg",
            "/BTS/DSC00205.jpg",
          ];
          const row1 = [...photos, ...photos];
          const row2 = [...[...photos].reverse(), ...[...photos].reverse()];
          return (
            <>
              <div class="bts-row bts-row--left">
                {row1.map((src) => (
                  <img src={src} alt="" class="bts-photo" />
                ))}
              </div>
              <div class="bts-row bts-row--right">
                {row2.map((src) => (
                  <img src={src} alt="" class="bts-photo" />
                ))}
              </div>
            </>
          );
        })()}
      </div>
    </section>
  </div>
</Layout>

<script>
  // Fade out the loading overlay once the Vimeo iframe fires its load event.
  // Falls back to a max wait of 4s so it never hangs indefinitely.
  (() => {
    const loader = document.getElementById("video-loader") as HTMLElement | null;
    const iframe = document.getElementById("vimeo-bg");
    if (!loader || !iframe) return;

    function dismiss() {
      loader!.classList.add("fade-out");
      loader!.addEventListener("transitionend", () => loader!.remove(), { once: true });
    }

    iframe.addEventListener("load", dismiss, { once: true });
    setTimeout(dismiss, 4000); // hard cap
  })();

  // Highly sensitive scroll snapping — any wheel input triggers the next/prev section
  (() => {
    const getSections = () =>
      Array.from(document.querySelectorAll<HTMLElement>(".snap-section, .accordion"));

    let locked = false;

    function snapTo(el: HTMLElement) {
      locked = true;
      el.scrollIntoView({ behavior: "smooth", block: "start" });
      setTimeout(() => { locked = false; }, 900);
    }

    function getCurrentIndex(sections: HTMLElement[]) {
      const mid = window.scrollY + window.innerHeight * 0.4;
      let idx = 0;
      sections.forEach((s, i) => {
        if (s.offsetTop <= mid) idx = i;
      });
      return idx;
    }

    window.addEventListener("wheel", (e) => {
      const sections = getSections();
      if (!sections.length) return;
      if (locked) { e.preventDefault(); return; }

      const dir = e.deltaY > 0 ? 1 : -1;
      const cur = getCurrentIndex(sections);
      const next = Math.max(0, Math.min(sections.length - 1, cur + dir));

      if (next !== cur) {
        e.preventDefault();
        snapTo(sections[next]);
      }
    }, { passive: false });

    let touchStartY = 0;
    window.addEventListener("touchstart", (e) => {
      touchStartY = e.touches[0].clientY;
    }, { passive: true });

    window.addEventListener("touchend", (e) => {
      if (locked) return;
      // Don't interfere with accordion panel taps
      if ((e.target as Element).closest?.('.accordion')) return;
      const sections = getSections();
      if (!sections.length) return;
      const dy = touchStartY - e.changedTouches[0].clientY;
      if (Math.abs(dy) < 30) return;
      const dir = dy > 0 ? 1 : -1;
      const cur = getCurrentIndex(sections);
      const next = Math.max(0, Math.min(sections.length - 1, cur + dir));
      if (next !== cur) snapTo(sections[next]);
    }, { passive: true });
  })();
</script>

<style>
  /* ── Video panel ── */
  .jester-panel {
    position: relative;
    height: calc(100svh - 3.5rem);
    scroll-snap-align: start;
    scroll-snap-stop: always;
    display: flex;
    flex-direction: column;
    border-top: 1px solid #1a1a18;
    overflow: hidden;
  }

  .jester-video-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .jester-video-bg iframe {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 177.78vh;
    height: 100%;
    min-width: 100%;
    min-height: 56.25vw;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .jester-video-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
  }

  /* Our Work button — right-aligned, vertically centered */
  .video-cta {
    position: relative;
    z-index: 1;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: 0 2.5rem;
  }

  .work-link {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: #C8A96E;
    transition: opacity 0.2s;
    border: 1px solid rgba(200, 169, 110, 0.45);
    padding: 0.9rem 2.5rem;
  }

  .work-link:hover {
    opacity: 0.7;
  }

  .work-label {
    font-family: "DM Mono", monospace;
    font-size: 0.85rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  /* Scroll hint arrow */
  .scroll-hint {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(240, 236, 224, 0.35);
    animation: bounce 2s ease-in-out infinite;
    pointer-events: none;
    z-index: 2;
  }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0);   opacity: 0.35; }
    50%       { transform: translateX(-50%) translateY(5px); opacity: 0.65; }
  }

  /* ── Ethos + BTS panel ── */
  .ethos-bts-panel {
    height: calc(100svh - 3.5rem);
    scroll-snap-align: start;
    scroll-snap-stop: always;
    display: flex;
    flex-direction: column;
    border-top: 1px solid #1a1a18;
    overflow: hidden;
  }

  .ethos {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-content: center;
    flex: 1;
    padding: 3rem 2.5rem;
  }

  .ethos-left {
    display: flex;
    align-items: flex-start;
  }

  .ethos-left span {
    font-family: "DM Mono", monospace;
    font-size: 1.5rem;
    letter-spacing: 0.1em;
    color: #F0ECE0;
    text-transform: lowercase;
  }

  .ethos-right p {
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(1.2rem, 2vw, 1.75rem);
    font-weight: 300;
    color: #F0ECE0;
    line-height: 1.6;
    letter-spacing: 0.01em;
  }

  .ethos-right p .gold {
    color: #C8A96E;
  }

  .ethos-link {
    display: inline-block;
    margin-top: 1.5rem;
    font-family: "DM Mono", monospace;
    font-size: 1.5rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #C8A96E;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .ethos-link:hover {
    opacity: 0.7;
  }

  /* ── BTS ── */
  .bts {
    flex: 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    padding: 2rem 0;
  }

  .bts-rows {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    flex: 1;
    justify-content: center;
  }

  .bts-row {
    display: flex;
    gap: 1rem;
    height: 14rem;
    will-change: transform;
  }

  .bts-row--left {
    animation: scroll-left 40s linear infinite;
  }

  .bts-row--right {
    animation: scroll-right 40s linear infinite;
  }

  @keyframes scroll-left {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @keyframes scroll-right {
    from { transform: translateX(-50%); }
    to   { transform: translateX(0); }
  }

  .bts-photo {
    flex-shrink: 0;
    height: 100%;
    width: auto;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    filter: grayscale(1);
  }

  /* ── Video loader ── */
  .video-loader {
    position: absolute;
    inset: 0;
    z-index: 3;
    background: #000;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.8s ease;
  }

  .video-loader.fade-out {
    opacity: 0;
    pointer-events: none;
  }

  .loader-logo {
    width: clamp(24rem, 60vw, 56rem);
    height: auto;
    animation: logo-pulse 2.2s ease-in-out infinite;
  }

  @keyframes logo-pulse {
    0%, 100% { opacity: 0.2;  transform: scale(0.82); }
    50%       { opacity: 0.65; transform: scale(1.12); }
  }

  @media (max-width: 640px) {
    .bts-rows {
      justify-content: center;
    }

    .bts-row--right {
      display: none;
    }

    .bts-row {
      height: 10rem;
    }

    .bts-photo {
      aspect-ratio: 4 / 3;
    }
  }
</style>
