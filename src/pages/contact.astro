---
import Layout from "../layouts/Layout.astro";

const sent = Astro.url.searchParams.get("sent") === "true";

const socials = [
  {
    label: "YouTube",
    href: "https://youtube.com",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>`,
  },
  {
    label: "TikTok",
    href: "https://tiktok.com",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.17 8.17 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/></svg>`,
  },
  {
    label: "Instagram",
    href: "https://instagram.com",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>`,
  },
];
---

<Layout title="Contact — New World Fool Productions" noSnap>
  <div class="contact-page">

    <header class="page-hero">
      <span class="label">Get In Touch</span>
      <h1>Contact</h1>
      <p class="subtitle">We'd love to collaborate with you on your next film, music video, or commercial. Reach out below and let's create something extraordinary together.</p>
    </header>

    {sent && (
      <div class="success-banner">
        Your message has been sent. We'll be in touch soon.
      </div>
    )}

    <div class="contact-body">

      <!-- Form -->
      <section class="form-section">
        <form
          class="contact-form"
          method="POST"
          action="https://formsubmit.co/newworldfoolproductions@gmail.com"
          id="contact-form"
        >
          <input type="hidden" name="_subject" value="New message from New World Fool Productions website" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_next" value="/contact?sent=true" />
          <div class="form-row">
            <div class="form-group">
              <label for="name">Name <span class="required" aria-label="required">*</span></label>
              <input type="text" id="name" name="name" required autocomplete="name" />
            </div>
            <div class="form-group">
              <label for="email">Email <span class="required" aria-label="required">*</span></label>
              <input type="email" id="email" name="email" required autocomplete="email" />
            </div>
          </div>

          <div class="form-group">
            <label for="subject">Subject</label>
            <input type="text" id="subject" name="subject" />
          </div>

          <div class="form-group">
            <label for="message">Message <span class="required" aria-label="required">*</span></label>
            <textarea id="message" name="message" rows="7" required></textarea>
          </div>

          <button type="submit" class="btn-submit">Send Message</button>
        </form>
      </section>

      <!-- Direct contact -->
      <aside class="contact-aside">
        <div class="aside-block">
          <span class="aside-label">Email us directly</span>
          <a href="mailto:newworldfoolproductions@gmail.com" class="contact-email">
            newworldfoolproductions<wbr />@gmail.com
          </a>
        </div>

        <div class="aside-block">
          <span class="aside-label">Follow along</span>
          <div class="social-icons">
            {socials.map(({ label, href, icon }) => (
              <a
                href={href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={label}
                class="social-icon"
                set:html={icon}
              />
            ))}
          </div>
        </div>
      </aside>

    </div>
  </div>
</Layout>

<style>
  .contact-page {
    min-height: 100vh;
    padding-bottom: 6rem;
  }

  /* ── Success banner ── */
  .success-banner {
    max-width: 1100px;
    margin: 2rem auto 0;
    padding: 1rem 2.5rem;
    background: rgba(200, 169, 110, 0.1);
    border: 1px solid rgba(200, 169, 110, 0.4);
    font-family: "DM Mono", monospace;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #C8A96E;
  }

  /* ── Hero ── */
  .page-hero {
    padding: 5rem 2.5rem 4rem;
    border-bottom: 1px solid #1a1a18;
    max-width: 1100px;
    margin: 0 auto;
  }

  .label {
    display: block;
    font-family: "DM Mono", monospace;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #C8A96E;
    margin-bottom: 1.25rem;
  }

  h1 {
    font-family: "Bebas Neue", sans-serif;
    font-size: clamp(5rem, 12vw, 10rem);
    font-weight: 400;
    line-height: 0.85;
    color: #F0ECE0;
    letter-spacing: 0.02em;
    margin-bottom: 1.75rem;
  }

  .subtitle {
    font-family: "Cormorant Garamond", serif;
    font-size: 1.1rem;
    font-style: italic;
    font-weight: 300;
    line-height: 1.75;
    color: rgba(240, 236, 224, 0.6);
    max-width: 520px;
  }

  /* ── Body layout ── */
  .contact-body {
    max-width: 1100px;
    margin: 0 auto;
    padding: 5rem 2.5rem;
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 6rem;
    align-items: start;
  }

  /* ── Form ── */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  label {
    font-family: "DM Mono", monospace;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(240, 236, 224, 0.45);
  }

  .required {
    color: #C8A96E;
  }

  input,
  textarea {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(240, 236, 224, 0.12);
    color: #F0ECE0;
    font-family: "Cormorant Garamond", serif;
    font-size: 1rem;
    font-weight: 300;
    padding: 0.85rem 1rem;
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
    resize: none;
    border-radius: 0;
    -webkit-appearance: none;
  }

  input::placeholder,
  textarea::placeholder {
    color: rgba(240, 236, 224, 0.2);
  }

  input:focus,
  textarea:focus {
    border-color: rgba(200, 169, 110, 0.5);
  }

  .btn-submit {
    display: inline-block;
    font-family: "DM Mono", monospace;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #000;
    background: #C8A96E;
    border: none;
    padding: 1rem 2.5rem;
    cursor: pointer;
    transition: opacity 0.2s;
    width: fit-content;
  }

  .btn-submit:hover {
    opacity: 0.85;
  }

  /* ── Aside ── */
  .contact-aside {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    padding-top: 0.5rem;
  }

  .aside-block {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .aside-label {
    font-family: "DM Mono", monospace;
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(240, 236, 224, 0.35);
  }

  .contact-email {
    font-family: "Cormorant Garamond", serif;
    font-size: 1rem;
    font-weight: 300;
    color: #C8A96E;
    text-decoration: none;
    line-height: 1.5;
    transition: opacity 0.2s;
    word-break: break-all;
  }

  .contact-email:hover {
    opacity: 0.7;
  }

  .social-icons {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .social-icon {
    color: rgba(240, 236, 224, 0.4);
    display: flex;
    align-items: center;
    transition: color 0.2s;
  }

  .social-icon:hover {
    color: #C8A96E;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .contact-body {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
  }

  @media (max-width: 640px) {
    .page-hero,
    .contact-body {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }

    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
