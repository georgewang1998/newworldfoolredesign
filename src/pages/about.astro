---
import Layout from "../layouts/Layout.astro";

const members = [
  {
    name: "Dylan Gaines",
    title: "Founder · Writer · Director · Producer",
    initials: "DG",
    photo: "/team/dylan.jpg",
    bio: `Dylan Gaines is the founder of New World Fool Productions and a writer, director, and producer based in New York City, crafting films that blur the lines between black comedy and horror. Originally from Boston, he received his degree in Cinema and Media Arts from Vanderbilt University in 2021.

His films expose the hypocrisies and uncomfortable truths of modern society, dissecting technological alienation, performative identity, and the systems of power that shape our lives — delivering pointed social critiques through visceral genre storytelling that refuses to look away.

Dylan's films have screened at festivals across the United States and internationally, garnering recognition for their distinctive voice and uncompromising vision. When not working on his next film project, Dylan can be found writing code as a software engineer or passionately cheering on his beloved Boston Celtics.`,
    imdbUrl: "https://www.imdb.com/name/nm16588878/",
  },
  {
    name: "Craig Helfer",
    title: "Writer · Director · Cinematographer",
    initials: "CH",
    photo: "/team/craig.jpg",
    objectPosition: "60% center",
    bio: `Craig Helfer's love for cinema began at age seven when he first saw Jurassic Park in a sold-out theater. That transformative experience sparked a lifelong passion that would shape his career as a writer, director, and cinematographer based in New Jersey.

As the creative force behind Iron Horse Cinema, Craig wrote, directed, and produced 20+ short films that accumulated 300,000+ subscribers and 46 million channel views on YouTube. His work spans corporate storytelling and independent filmmaking, with expertise in cinematography, lighting, and post-production.

With over a decade of experience, Craig has worked with high-profile clients including Hilton, Nissan, Goldman Sachs, and Adidas, creating content with over 120 million views across digital platforms.`,
    imdbUrl: "https://craighelfer.com/",
    imdbLabel: "Portfolio →",
  },
  {
    name: "George Wang",
    title: "Producer",
    initials: "GW",
    photo: "/team/george.jpg",
    bio: `George Wang is a New York City-based producer with a lifelong passion for storytelling and a proven track record of bringing creative visions to life. He wrote, directed, and produced his first feature film in high school, premiering it to an audience of over 200 people and earning coverage in local press.

In college, he founded his school's first filmmaking club, growing it from a small circle of friends to over 70 active members producing 40+ short films, earning recognition at national film festivals, and raising more than $20K in funding.

Beyond the camera, George brings a sharp business mind to his work, drawing on his background in finance and his experience as a nonprofit treasurer overseeing operational and financial decision-making.`,
    imdbUrl: undefined,
  },
  {
    name: "Varun Giridhar",
    title: "Writer · Director · Producer",
    initials: "VG",
    photo: "/team/varun.jpg",
    bio: `Varun Giridhar is a writer, director, and producer based in New York City who makes films grounded in universal emotions — often with a sharp twist of dark humor or an inventive genre inflection. Born in India and brought up in America, Varun seeks to bring a global perspective to his creative work that prioritizes the audience's experience of watching a film.

In college, Varun wrote and directed several short films and a feature film. After graduation, he has written and directed eight short films and written four feature specs. Varun also writes prose, having written several short stories and a novel.

As a filmmaker, Varun seeks to achieve something different with each project — having directed narrative short films shot on iPhones, digital cameras, on 16mm, and on 35mm. He believes each project is an opportunity to test one's limits both technically and emotionally.`,
    imdbUrl: undefined,
  },
];
---

<Layout title="About — New World Fool Productions" noSnap>
  <div class="about-page">

    <header class="page-hero">
      <span class="label">Who We Are</span>
      <h1>About</h1>
      <div class="mission">
        <p>We live in a world drenched in arrogance, greed, and corruption. By invoking the medieval iconography of the "court jester," New World Fool Productions seeks to illuminate these blatant hypocrisies through a variety of visual media formats.</p>
      </div>
    </header>

    <section class="team-section">
      <div class="team-header">
        <span class="section-label">The Team</span>
      </div>
      <div class="team-list">
        {members.map((member) => (
          <div class="member">
            <div class="member-left">
              <div class="member-photo-wrap">
                <img src={member.photo} alt={member.name} class="member-photo" style={member.objectPosition ? `object-position: ${member.objectPosition}` : undefined} />
              </div>
            </div>
            <div class="member-right">
              <div class="member-header">
                <h2 class="member-name">{member.name}</h2>
                <span class="member-title">{member.title}</span>
              </div>
              <div class="member-bio">
                {member.bio.split("\n\n").map((para) => (
                  <p>{para}</p>
                ))}
              </div>
              {member.imdbUrl && (
                <a
                  href={member.imdbUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="member-link"
                >
                  {member.imdbLabel ?? "IMDb →"}
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </section>

  </div>
</Layout>

<style>
  .about-page {
    min-height: 100vh;
    padding-bottom: 6rem;
  }

  /* ── Hero ── */
  .page-hero {
    padding: 5rem 2.5rem 5rem;
    border-bottom: 1px solid #1a1a18;
    max-width: 1100px;
    margin: 0 auto;
  }

  .label {
    display: block;
    font-family: "DM Mono", monospace;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #C8A96E;
    margin-bottom: 1.25rem;
  }

  h1 {
    font-family: "Bebas Neue", sans-serif;
    font-size: clamp(5rem, 12vw, 10rem);
    font-weight: 400;
    line-height: 0.85;
    color: #F0ECE0;
    letter-spacing: 0.02em;
    margin-bottom: 3rem;
  }

  .mission {
    max-width: 680px;
    border-left: 2px solid #C8A96E;
    padding-left: 2rem;
  }

  .mission p {
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    font-weight: 300;
    line-height: 1.75;
    color: rgba(240, 236, 224, 0.75);
  }

  /* ── Team ── */
  .team-section {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2.5rem;
  }

  .team-header {
    padding: 4rem 0 3rem;
    border-bottom: 1px solid #1a1a18;
  }

  .section-label {
    font-family: "DM Mono", monospace;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(240, 236, 224, 0.35);
  }

  .team-list {
    display: flex;
    flex-direction: column;
  }

  .member {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 4rem;
    padding: 4rem 0;
    border-bottom: 1px solid #1a1a18;
  }

  /* ── Photo ── */
  .member-left {
    display: flex;
    justify-content: center;
  }

  .member-photo-wrap {
    width: 280px;
    aspect-ratio: 3/4;
    overflow: hidden;
    flex-shrink: 0;
  }

  .member-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    filter: grayscale(30%);
    transition: filter 0.4s ease;
  }

  .member:hover .member-photo {
    filter: grayscale(0%);
  }

  /* ── Info ── */
  .member-right {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .member-header {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .member-name {
    font-family: "Bebas Neue", sans-serif;
    font-size: clamp(3rem, 5vw, 4.5rem);
    font-weight: 400;
    line-height: 1;
    color: #F0ECE0;
    letter-spacing: 0.02em;
  }

  .member-title {
    font-family: "DM Mono", monospace;
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(240, 236, 224, 0.4);
  }

  .member-bio {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .member-bio p {
    font-family: "Cormorant Garamond", serif;
    font-size: 1.05rem;
    font-weight: 300;
    line-height: 1.8;
    color: rgba(240, 236, 224, 0.65);
  }

  .member-link {
    display: inline-block;
    font-family: "DM Mono", monospace;
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #C8A96E;
    text-decoration: none;
    transition: opacity 0.2s;
    width: fit-content;
    border-bottom: 1px solid rgba(200, 169, 110, 0.4);
    padding-bottom: 0.15rem;
  }

  .member-link:hover {
    opacity: 0.7;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .member {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .member-left {
      justify-content: flex-start;
    }

    .member-photo-wrap {
      width: 220px;
    }
  }

  @media (max-width: 640px) {
    .page-hero,
    .team-section {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }

    .mission {
      padding-left: 1.25rem;
    }
  }
</style>
