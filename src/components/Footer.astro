---
const links = [
  { label: "Work", href: "/work" },
  { label: "About", href: "/about" },
  { label: "Contact", href: "/contact" },
];

const socials = [
  {
    label: "YouTube",
    href: "https://youtube.com",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>`,
  },
  {
    label: "TikTok",
    href: "https://tiktok.com",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.17 8.17 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/></svg>`,
  },
  {
    label: "Instagram",
    href: "https://instagram.com",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>`,
  },
];
---

<footer>
  <div class="footer-top">
    <a href="/" class="footer-logo">
      <img src="/logo.png" alt="New World Fool Productions" class="footer-logo-img" />
    </a>
    <nav class="footer-nav">
      {links.map(({ label, href }) => (
        <a href={href}>{label}</a>
      ))}
    </nav>
    <div class="footer-socials">
      {socials.map(({ label, href, icon }) => (
        <a href={href} target="_blank" rel="noopener noreferrer" aria-label={label} set:html={icon} />
      ))}
    </div>
  </div>

  <div class="footer-bottom">
    <span class="footer-copy">&copy; {new Date().getFullYear()} New World Fool Productions. All rights reserved.</span>
  </div>
</footer>

<style>
  footer {
    background: #0A0A08;
    border-top: 1px solid #1a1a18;
    padding: 4rem 2.5rem 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 3rem;
    scroll-snap-align: start;
  }

  .footer-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }

  .footer-logo {
    text-decoration: none;
    display: flex;
    align-items: center;
    transition: opacity 0.2s;
    line-height: 1;
  }

  .footer-logo:hover {
    opacity: 0.6;
  }

  .footer-logo-img {
    height: 5rem;
    width: auto;
    display: block;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-nav a {
    font-family: "DM Mono", monospace;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #F0ECE040;
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-nav a:hover {
    color: #C8A96E;
  }

  .footer-socials {
    display: flex;
    gap: 1.25rem;
    align-items: center;
  }

  .footer-socials a {
    color: #F0ECE040;
    display: flex;
    align-items: center;
    transition: color 0.2s;
  }

  .footer-socials a:hover {
    color: #C8A96E;
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 2rem;
    border-top: 1px solid #1a1a18;
  }

  .footer-tagline {
    font-family: "Cormorant Garamond", serif;
    font-size: 0.9rem;
    font-style: italic;
    font-weight: 300;
    color: #F0ECE040;
    letter-spacing: 0.02em;
  }

  .footer-copy {
    font-family: "DM Mono", monospace;
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    color: #F0ECE020;
    text-transform: uppercase;
  }
</style>
