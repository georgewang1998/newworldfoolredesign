---
const projects = [
  {
    index: "01",
    title: "Piggy",
    year: "2025",
    category: "Short Film",
    director: "Dylan Gaines",
    description: "After bombing yet another open mic, a struggling obese comedian takes drastic measures to obtain the validation he’s always craved.",
    image: "/FilmScreengrabs/Piggy_still.png",
    href: "/films/piggy",
  },
  {
    index: "02",
    title: "Mukbang’d",
    year: "2025",
    category: "Short Film",
    director: "Dylan Gaines",
    description: "A mukbang influencer begins to film another day of her scarfing and spitting out piles of food. Until a mysterious accident causes things to spiral out of control…",
    image: "/FilmScreengrabs/Mukbang_still.png",
    href: "/films/mukbangd",
  },
  {
    index: "03",
    title: "Unforeseen",
    year: "2025",
    category: "Short Film",
    director: "Craig Helfer & Dylan Gaines",
    description: "An ambitious film crew shoots a horror film in what they think is an abandoned warehouse. But as the crew splinters, an unforeseen entity comes to visit.",
    image: "/FilmScreengrabs/Unforeseen_still.png",
    href: "/films/unforeseen",
  },
  {
    index: "04",
    title: "The Hunter",
    year: "2024",
    category: "Short Film",
    director: "Dylan Gaines",
    description: "An arrogant hunter heads into the woods for what he thinks is a typical day of sport. But things change when it turns out he is the one being hunted…",
    image: "/FilmScreengrabs/Hunter_still.png",
    href: "/films/hunter",
  },
];
---

<section class="accordion">
  {projects.map((p) => (
    <a href={p.href} class="project" aria-label={p.title}>
      <img src={p.image} alt={p.title} class="bg" />
      <div class="overlay" />

      <!-- Shown when collapsed -->
      <div class="collapsed-info">
        <span class="rotated-label"><span class="rotated-title">{p.title}</span>&ensp;<span class="rotated-year">{p.year}</span></span>
      </div>

      <!-- Shown when expanded -->
      <div class="expanded-info">
        <span class="index">{p.index}</span>
        <div class="details">
          <span class="meta">{p.year}&nbsp;·&nbsp;{p.category}</span>
          <h2 class="title">{p.title}</h2>
          <p class="description">{p.description}</p>
          <span class="director">dir. {p.director}</span>
        </div>
      </div>
    </a>
  ))}

  <div class="scroll-hint" aria-hidden="true">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
      <path d="M8 3v10M3 9l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
</section>

<style>
  .accordion {
    position: relative;
    display: flex;
    height: calc(100svh - 3.5rem);
    gap: 2px;
    scroll-snap-align: start;
    scroll-snap-stop: always;
  }

  /* --- Panel sizing --- */
  .project {
    position: relative;
    flex: 0.4;
    overflow: hidden;
    cursor: pointer;
    transition: flex 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
    color: inherit;
    display: block;
  }

  /* First panel expanded by default */
  .project:first-child {
    flex: 4;
  }

  /* When accordion is hovered, collapse first panel unless it's being hovered */
  .accordion:hover .project:first-child {
    flex: 0.4;
  }

  .accordion:hover .project:hover {
    flex: 4;
  }

  /* --- Background --- */
  .bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .project:hover .bg {
    transform: scale(1.04);
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.3) 50%, rgba(0,0,0,0.15) 100%);
  }

  /* --- Collapsed info (rotated title + year) --- */
  .collapsed-info {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 1;
    transition: opacity 0.3s ease;
  }

  .rotated-label {
    color: rgba(255,255,255,0.7);
    letter-spacing: 0.08em;
    white-space: nowrap;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    font-family: "Bebas Neue", sans-serif;
  }

  .rotated-title {
    font-size: 4.2rem;
  }

  .rotated-year {
    font-size: 1.05rem;
  }

  /* --- Expanded info --- */
  .expanded-info {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 1.5rem;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .index {
    font-family: "DM Mono", monospace;
    font-size: 0.7rem;
    color: rgba(255,255,255,0.35);
    letter-spacing: 0.08em;
  }

  .details {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .meta {
    font-family: "DM Mono", monospace;
    font-size: 0.975rem;
    color: #C8A96E;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transform: translateY(6px);
    transition: transform 0.3s ease 0.1s;
  }

  .title {
    font-family: "Bebas Neue", sans-serif;
    font-size: clamp(6rem, 9vw, 10.5rem);
    font-weight: 400;
    color: #F0ECE0;
    white-space: nowrap;
    line-height: 1;
  }

  .description {
    font-family: "Cormorant Garamond", serif;
    font-size: 1.08rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.6;
    max-width: 55ch;
    transform: translateY(8px);
    transition: transform 0.3s ease 0.15s;
  }

  .director {
    font-family: "DM Mono", monospace;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    color: #C8A96E;
    text-transform: lowercase;
    margin-top: 0.4rem;
  }

  /* --- Expanded state --- */
  /* First child expanded by default */
  .project:first-child .collapsed-info { opacity: 0; }
  .project:first-child .expanded-info  { opacity: 1; }

  /* When accordion is hovered, revert first child */
  .accordion:hover .project:first-child .collapsed-info { opacity: 1; }
  .accordion:hover .project:first-child .expanded-info  { opacity: 0; }

  /* Hovered panel gets expanded state */
  .accordion:hover .project:hover .collapsed-info { opacity: 0; }
  .accordion:hover .project:hover .expanded-info  { opacity: 1; }

  .accordion:hover .project:hover .meta,
  .accordion:hover .project:hover .description,
  .project:first-child .meta,
  .project:first-child .description {
    transform: translateY(0);
  }

  /* --- Scroll hint arrow --- */
  .scroll-hint {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(240, 236, 224, 0.35);
    animation: bounce 2s ease-in-out infinite;
    pointer-events: none;
    z-index: 2;
  }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); opacity: 0.35; }
    50%       { transform: translateX(-50%) translateY(5px); opacity: 0.65; }
  }

  @media (max-width: 640px) {
    .title {
      font-size: clamp(3rem, 11vw, 5.5rem);
    }

    .rotated-title {
      font-size: 2.8rem;
    }

    .description {
      font-size: 0.9rem;
    }

    .expanded-info {
      padding: 1rem;
    }
  }

  /* ── Mobile touch behavior ── */
  @media (hover: none) {
    /* Reset first-child default expanded state — JS will manage it */
    .project:first-child { flex: 0.4; }
    .project:first-child .collapsed-info { opacity: 1; }
    .project:first-child .expanded-info  { opacity: 0; }
    .project:first-child .meta,
    .project:first-child .description { transform: translateY(6px); }

    /* Disable desktop hover overrides */
    .accordion:hover .project:first-child { flex: 0.4; }
    .accordion:hover .project:hover { flex: 0.4; }
    .accordion:hover .project:hover .collapsed-info { opacity: 1; }
    .accordion:hover .project:hover .expanded-info  { opacity: 0; }

    /* Touch-active panel */
    .project.touch-active { flex: 4; }
    .project.touch-active .collapsed-info { opacity: 0; }
    .project.touch-active .expanded-info  { opacity: 1; }
    .project.touch-active .meta,
    .project.touch-active .description { transform: translateY(0); }
    .project.touch-active .bg { transform: scale(1.04); }
  }
</style>

<script>
  const isTouch = navigator.maxTouchPoints > 0 || 'ontouchstart' in window;

  if (isTouch) {
    const accordion = document.querySelector('.accordion');
    if (accordion) {
      const panels = [...accordion.querySelectorAll<HTMLAnchorElement>('.project')];

      // Start with first panel active
      panels[0].classList.add('touch-active');

      panels.forEach((panel) => {
        let moved = false;

        panel.addEventListener('touchstart', () => { moved = false; }, { passive: true });
        panel.addEventListener('touchmove',  () => { moved = true;  }, { passive: true });

        panel.addEventListener('touchend', (e) => {
          if (moved) return;
          if (panel.classList.contains('touch-active')) {
            // Already expanded — navigate
            window.location.href = panel.href;
            return;
          }
          // First tap — expand only
          e.preventDefault();
          panels.forEach((p) => p.classList.remove('touch-active'));
          panel.classList.add('touch-active');
        }, { passive: false });

        // Block click-based navigation for non-active panels (fallback)
        panel.addEventListener('click', (e) => {
          if (!panel.classList.contains('touch-active')) e.preventDefault();
        });
      });
    }
  }
</script>
